# ─────────────────────────────────────────────────────────────────────────────
# Iris API environment. Copy to apps/api/.env for local dev.
# The foundation runs with ZERO of these set (PGlite + local auth + fake Stripe).
# Set them to move toward production.
# ─────────────────────────────────────────────────────────────────────────────

# --- Server ---
PORT=4000
NODE_ENV=development
# Public base URL of this API (used in Stripe redirect URLs, etc.)
API_BASE_URL=http://localhost:4000

# --- Database ---
# If DATABASE_URL is set, the API uses node-postgres against that cluster.
# If it is UNSET, the API uses PGlite (in-process Postgres) at PGLITE_PATH.
# DATABASE_URL=postgres://user:pass@localhost:5432/iris
PGLITE_PATH=.data/iris

# --- Auth ---
# AUTH_PROVIDER: local (default) | clerk | supabase  (only "local" is implemented; others are seams)
AUTH_PROVIDER=local
# Secret used to sign session JWTs. CHANGE THIS. A random value is used if unset (dev only).
JWT_SECRET=dev-only-change-me-to-a-32+char-random-string

# --- Billing (Stripe) ---
# If STRIPE_SECRET_KEY is unset, a fake in-memory Stripe is used so the gate logic still runs.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...           # the ~$5/mo sync plan
# Where Stripe Checkout sends the user back (deep link into the app):
STRIPE_SUCCESS_URL=iris://billing/success
STRIPE_CANCEL_URL=iris://billing/cancel

# --- Client (apps/mobile) ---
# The mobile/web client reads this to find the API. Prefix EXPO_PUBLIC_ is required by Expo.
EXPO_PUBLIC_API_URL=http://localhost:4000
